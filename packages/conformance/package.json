{
  "name": "@webmcpregistry/conformance",
  "version": "0.2.1",
  "description": "WebMCP W3C specification conformance test suite — verify any navigator.modelContext implementation against the standard",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^29.0.0",
    "tsup": "^8.4.0",
    "vitest": "^4.1.4",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "webmcp",
    "conformance",
    "w3c",
    "test-suite",
    "specification"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelvinay91/webmcpregistry.git",
    "directory": "packages/conformance"
  },
  "bugs": {
    "url": "https://github.com/samuelvinay91/webmcpregistry/issues"
  },
  "homepage": "https://github.com/samuelvinay91/webmcpregistry#readme"
}
