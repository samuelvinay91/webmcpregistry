{
  "name": "@webmcpregistry/mcp-server",
  "version": "0.2.0",
  "description": "MCP server that discovers, executes, and validates WebMCP tools on any website — powered by Playwright",
  "license": "Apache-2.0",
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "peerDependencies": {
    "playwright": "^1.50.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "playwright": "^1.50.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "webmcp", "mcp", "mcp-server", "playwright", "browser",
    "ai-agents", "claude", "chatgpt", "testing", "discovery"
  ]
}
