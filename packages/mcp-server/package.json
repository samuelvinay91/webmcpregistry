{
  "name": "@webmcpregistry/mcp-server",
  "version": "0.2.0",
  "description": "MCP server that bridges Anthropic's MCP to WebMCP — lets Claude/ChatGPT call website tools directly",
  "license": "Apache-2.0",
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "mcp-server",
    "bridge",
    "ai-agents",
    "claude",
    "chatgpt"
  ]
}
