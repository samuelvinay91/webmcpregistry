{
  "name": "@webmcpregistry/mcp-server",
  "version": "0.2.1",
  "description": "MCP server that discovers, executes, and validates WebMCP tools on any website — Playwright baked in",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "webmcp-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist",
    "postinstall": "playwright install chromium 2>/dev/null || true"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "mcp-server",
    "playwright",
    "browser",
    "ai-agents",
    "claude",
    "chatgpt",
    "testing",
    "discovery"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelvinay91/webmcpregistry.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/samuelvinay91/webmcpregistry/issues"
  },
  "homepage": "https://github.com/samuelvinay91/webmcpregistry#readme"
}
