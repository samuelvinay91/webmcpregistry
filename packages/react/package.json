{
  "name": "@webmcpregistry/react",
  "version": "0.2.1",
  "description": "React hooks and components for WebMCP tool registration",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "vitest": "^4.1.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "webmcp",
    "react",
    "hooks",
    "ai-agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelvinay91/webmcpregistry.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/samuelvinay91/webmcpregistry/issues"
  },
  "homepage": "https://github.com/samuelvinay91/webmcpregistry#readme"
