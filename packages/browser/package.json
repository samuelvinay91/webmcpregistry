{
  "name": "@webmcpregistry/browser",
  "version": "0.2.1",
  "description": "Drop-in <script> tag to make any website WebMCP-ready — zero framework required",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/auto.global.js",
  "module": "./dist/auto.js",
  "types": "./dist/auto.d.ts",
  "exports": {
    ".": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webmcpregistry/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^4.1.4",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "webmcp",
    "script-tag",
    "ai-agents",
    "no-framework"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelvinay91/webmcpregistry.git",
    "directory": "packages/browser"
  },
  "bugs": {
    "url": "https://github.com/samuelvinay91/webmcpregistry/issues"
  },
  "homepage": "https://github.com/samuelvinay91/webmcpregistry#readme"
}
