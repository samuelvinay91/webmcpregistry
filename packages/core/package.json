{
  "name": "@webmcpregistry/core",
  "version": "0.2.1",
  "description": "Framework-agnostic WebMCP SDK core — polyfill, tool detection, registration, validation",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "author": "RAPHATECH OÜ",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "jsdom": "^29.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "browser-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelvinay91/webmcpregistry.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/samuelvinay91/webmcpregistry/issues"
  },
  "homepage": "https://github.com/samuelvinay91/webmcpregistry#readme"
}
